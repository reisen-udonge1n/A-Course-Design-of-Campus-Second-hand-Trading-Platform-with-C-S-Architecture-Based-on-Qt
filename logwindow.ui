  <property name="styleSheet">
   <string notr="true">
    QWidget#LoginWindow {
        background-color: #f5f6fa;
        border-radius: 10px;
    }

    QLabel#titleLabel {
        font-size: 26px;
        font-weight: bold;
        color: #2c3e50;
        qproperty-alignment: AlignCenter;
    }

    QLabel#subtitleLabel {
        font-size: 13px;
        color: #7f8c8d;
        qproperty-alignment: AlignCenter;
    }

    QWidget#inputPanel {
        background-color: #ffffff;
        border-radius: 12px;
    }

    QLineEdit {
        min-height: 42px;
        padding: 0 15px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 14px;
        background-color: #fafafa;
        color: #333333;
        selection-background-color: #3498db;
    }

    QLineEdit:focus {
        border-color: #3498db;
        background-color: #ffffff;
    }

    QLineEdit:hover {
        border-color: #bdc3c7;
    }

    QPushButton#loginBtn {
        background-color: #3498db;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 14px;
        font-size: 16px;
        font-weight: bold;
    }

    QPushButton#loginBtn:hover {
        background-color: #2980b9;
    }

    QPushButton#loginBtn:pressed {
        background-color: #2471a3;
    }

    QPushButton#registerBtn {
        background-color: #ffffff;
        color: #3498db;
        border: 2px solid #3498db;
        border-radius: 8px;
        padding: 14px;
        font-size: 16px;
        font-weight: bold;
    }

    QPushButton#registerBtn:hover {
        background-color: #ebf5fb;
    }

    QPushButton#registerBtn:pressed {
        background-color: #d4e6f1;
    }

    QPushButton#forgotPwdBtn {
        background: transparent;
        border: none;
        color: #3498db;
        font-size: 13px;
        text-decoration: underline;
    }

    QPushButton#forgotPwdBtn:hover {
        color: #2980b9;
    }
   </string>
